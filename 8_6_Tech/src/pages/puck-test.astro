---
// src/pages/puck-test.astro
// Bản nâng cấp: Thêm đầy đủ thuộc tính định dạng chữ (Cỡ chữ, Màu sắc, Độ đậm, Line-height, Nền, Padding) cho khối Văn Bản
---

<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <title>Hệ thống Thử Nghiệm Kéo Thả của Phúc</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>
  <body>

    <div id="puck-root"></div>

    <script>
      import React from 'react';
      import { createRoot } from 'react-dom/client';
      import { Puck } from '@measured/puck';
      import '@measured/puck/dist/index.css';

      // --- CẤU HÌNH NỀN CHUNG NÂNG CAO ---
      const backgroundFields = {
        type: {
          type: 'select',
          label: 'Loại',
          options: [
            { label: 'Màu', value: 'color' },
            { label: 'Gradient', value: 'gradient' },
            { label: 'Hình ảnh', value: 'image' }
          ]
        },
        color: { type: 'text', label: 'Màu nền' },
        gradient_from: { type: 'text', label: 'Gradient từ' },
        gradient_to: { type: 'text', label: 'Gradient đến' },
        gradient_direction: { type: 'text', label: 'Hướng gradient' },
        bg_image_url: { type: 'text', label: 'URL ảnh nền' },
        opacity: { type: 'number', label: 'Độ mờ (0 - 1)' },
        padding_x: { type: 'number', label: 'Padding ngang' },
        padding_y: { type: 'number', label: 'Padding dọc' }
      };

      const defaultBackgroundProps = {
        type: 'color',
        color: '#ffffff',
        gradient_from: '',
        gradient_to: '',
        gradient_direction: 'to right',
        bg_image_url: '',
        opacity: 1,
        padding_x: 4,
        padding_y: 4
      };

      const getBackgroundStyle = (bg) => {
        if (!bg) return {};
        let style = {};
        if (bg.type === 'color' && bg.color) {
          style.backgroundColor = bg.color;
        } else if (bg.type === 'gradient' && bg.gradient_from && bg.gradient_to) {
          const dir = bg.gradient_direction || 'to right';
          style.background = `linear-gradient(${dir}, ${bg.gradient_from}, ${bg.gradient_to})`;
        } else if (bg.type === 'image' && bg.bg_image_url) {
          style.backgroundImage = `url(${bg.bg_image_url})`;
          style.backgroundSize = 'cover';
          style.backgroundPosition = 'center';
        }
        if (bg.opacity !== undefined) style.opacity = bg.opacity;
        const pX = bg.padding_x !== undefined ? bg.padding_x * 8 : 32;
        const pY = bg.padding_y !== undefined ? bg.padding_y * 8 : 32;
        style.padding = `${pY}px ${pX}px`;
        return style;
      };

      const puckConfigLocal = {
        components: {
          Heading: {
            label: 'Tiêu đề',
            fields: {
              content: { type: 'text', label: 'Nội dung' },
              level: {
                type: 'select', label: 'Cấp độ',
                options: [
                  { label: 'H1', value: 1 }, { label: 'H2', value: 2 },
                  { label: 'H3', value: 3 }, { label: 'H4', value: 4 }
                ]
              },
              align: {
                type: 'select', label: 'Căn lề',
                options: [
                  { label: 'Trái', value: 'left' },
                  { label: 'Giữa', value: 'center' },
                  { label: 'Phải', value: 'right' }
                ]
              }
            },
            defaultProps: { content: 'Tiêu đề mới', level: 2, align: 'left' },
            render: ({ content, level, align }) => {
              const Tag = `h${level}`;
              return React.createElement(Tag, { style: { textAlign: align } }, content);
            }
          },

          // --- COMPONENT VĂN BẢN NÂNG CẤP TOÀN DIỆN ĐÚNG Ý PHÚC ---
          Text: {
            label: 'Văn bản',
            fields: {
              content: { type: 'textarea', label: 'Nội dung văn bản' },
              align: {
                type: 'select',
                label: 'Căn lề chữ',
                options: [
                  { label: 'Căn trái', value: 'left' },
                  { label: 'Căn giữa', value: 'center' },
                  { label: 'Căn phải', value: 'right' },
                  { label: 'Căn đều hai bên', value: 'justify' }
                ]
              },
              // Định dạng chữ nâng cao
              fontSize: { type: 'number', label: 'Cỡ chữ (px)' },
              color: { type: 'text', label: 'Màu chữ (Mã màu HEX hoặc tên tiếng Anh)' },
              fontWeight: {
                type: 'select',
                label: 'Độ đậm của chữ',
                options: [
                  { label: 'Mỏng (Light)', value: '300' },
                  { label: 'Bình thường (Normal)', value: '400' },
                  { label: 'Vừa (Medium)', value: '500' },
                  { label: 'Bán đậm (Semi-Bold)', value: '600' },
                  { label: 'Đậm (Bold)', value: '700' }
                ]
              },
              lineHeight: { type: 'text', label: 'Khoảng cách dòng (VD: 1.5, 1.8 hoặc 24px)' },
              
              // Tinh chỉnh khung khối chữ nâng cao
              customBgColor: { type: 'text', label: 'Màu nền riêng của khối chữ (Nếu có)' },
              borderRadius: { type: 'number', label: 'Bo góc nền khối chữ (px)' },
              paddingTopBottom: { type: 'number', label: 'Padding dọc khối chữ (px)' },
              paddingLeftRight: { type: 'number', label: 'Padding ngang khối chữ (px)' }
            },
            defaultProps: { 
              content: 'Nhập nội dung văn bản mới vào đây...', 
              align: 'left',
              fontSize: 15,
              color: '#334155',
              fontWeight: '400',
              lineHeight: '1.6',
              customBgColor: 'transparent',
              borderRadius: 0,
              paddingTopBottom: 0,
              paddingLeftRight: 0
            },
            render: ({ content, align, fontSize, color, fontWeight, lineHeight, customBgColor, borderRadius, paddingTopBottom, paddingLeftRight }) => {
              const textStyles = {
                textAlign: align || 'left',
                fontSize: fontSize ? `${fontSize}px` : '15px',
                color: color || '#334155',
                fontWeight: fontWeight || '400',
                lineHeight: lineHeight || '1.6',
                backgroundColor: customBgColor || 'transparent',
                borderRadius: `${borderRadius || 0}px`,
                padding: `${paddingTopBottom || 0}px ${paddingLeftRight || 0}px`,
                margin: '0',
                width: '100%',
                boxSizing: 'border-box'
              };

              return React.createElement(
                'p', 
                { style: textStyles, className: "whitespace-pre-wrap" }, 
                content
              );
            }
          },

          // --- COMPONENT ẢNH ---
          Image: {
            label: 'Ảnh',
            fields: {
              url: { type: 'text', label: 'URL Hình ảnh' },
              alt: { type: 'text', label: 'Mô tả ảnh (Alt)' },
              width: { type: 'text', label: 'Chiều rộng (VD: 100%, 300px, auto)' },
              height: { type: 'text', label: 'Chiều cao (VD: auto, 200px)' },
              borderRadius: { type: 'number', label: 'Bo góc ảnh (px)' },
              align: {
                type: 'select',
                label: 'Căn vị trí khối ảnh',
                options: [{ label: 'Căn trái', value: 'left' }, { label: 'Căn giữa', value: 'center' }, { label: 'Căn phải', value: 'right' }]
              }
            },
            defaultProps: { url: '', alt: '', width: '100%', height: 'auto', borderRadius: 8, align: 'center' },
            render: ({ url, alt, width, height, borderRadius, align }) => {
              if (!url) {
                return React.createElement('div', { style: { padding: '30px', background: '#e2e8f0', textAlign: 'center', borderRadius: '8px', fontSize: '14px', color: '#64748b', border: '1px dashed #cbd5e1' } }, 'Chưa nhập URL hình ảnh');
              }
              let justifyContent = 'center';
              if (align === 'left') justifyContent = 'flex-start';
              if (align === 'right') justifyContent = 'flex-end';

              return React.createElement(
                'div', { style: { display: 'flex', width: '100%', justifyContent: justifyContent, margin: '10px 0' } },
                React.createElement('img', { src: url, alt: alt, style: { width: width || '100%', height: height || 'auto', borderRadius: `${borderRadius || 0}px`, display: 'block', objectFit: 'cover' } })
              );
            }
          },

          // --- COMPONENT KHOẢNG (SECTION) ---
          Section: {
            label: 'Khoảng (Section)',
            fields: {
              container: {
                type: 'select', label: 'Chiều rộng',
                options: [{ label: 'Small', value: 'sm' }, { label: 'Medium', value: 'md' }, { label: 'Large', value: 'lg' }]
              },
              background: { type: 'object', label: 'Background', objectFields: backgroundFields }
            },
            defaultProps: { container: 'lg', background: defaultBackgroundProps },
            render: ({ container, background, children }) => {
              const bgStyle = getBackgroundStyle(background);
              return React.createElement(
                'section', { style: { ...bgStyle, border: '1px dashed #ccc' } },
                React.createElement('div', { style: { maxWidth: '1280px', margin: '0 auto' } }, children)
              );
            }
          },

          // --- COMPONENT CÁC BAN CHUYÊN MÔN ---
          CácBanChuyênMôn: {
            label: 'Các Ban Chuyên Môn ',
            fields: {
              title: { type: 'text', label: 'Tiêu đề chính' },
              subtitle: { type: 'text', label: 'Tiêu đề phụ' },
              cluster_align: {
                type: 'select',
                label: 'Căn lề toàn cụm',
                options: [{ label: 'Bên trái', value: 'flex-start' }, { label: 'Nằm giữa', value: 'center' }, { label: 'Bên phải', value: 'flex-end' }]
              },
              container_radius: { type: 'number', label: 'Bo góc nguyên cụm (px)' },
              background: { type: 'object', label: 'Cấu hình Nền & Padding', objectFields: backgroundFields },
              items: {
                type: 'array',
                label: 'Danh sách các Ban',
                getItemSummary: (item) => item.name || 'Ban chưa đặt tên',
                arrayFields: {
                  name: { type: 'text', label: 'Tên Ban' },
                  icon: { type: 'text', label: 'Icon (Emoji hoặc URL ảnh)' },
                  button_text: { type: 'text', label: 'Chữ trên nút hành động' },
                  custom_button_color: { type: 'text', label: 'Màu nền nút cục bộ' },
                  custom_button_radius: { type: 'number', label: 'Bo góc nút cục bộ (px)' },
                  custom_text_color: { type: 'text', label: 'Màu chữ nút cục bộ' },
                  custom_text_size: { type: 'number', label: 'Cỡ chữ nút cục bộ (px)' }
                }
              }
            },
            defaultProps: { title: 'CÁC BAN CHUYÊN MÔN', subtitle: 'DANH SÁCH KHỐI CHUYÊN MÔN', cluster_align: 'center', container_radius: 12, background: defaultBackgroundProps, items: [] },
            render: ({ title, subtitle, cluster_align, container_radius, background, items = [] }) => {
              const bgStyle = getBackgroundStyle(background);
              return React.createElement(
                'div', { style: { ...bgStyle, display: 'flex', flexDirection: 'column', alignItems: cluster_align, width: '100%', boxSizing: 'border-box' } },
                React.createElement('div', { style: { display: 'flex', flexDirection: 'column', alignItems: 'center', gap: '20px', maxWidth: '1000px', width: '100%', borderRadius: `${container_radius || 0}px`, padding: '24px', background: 'rgba(255, 255, 255, 0.6)', backdropFilter: 'blur(8px)', boxShadow: '0 4px 15px rgba(0,0,0,0.05)' } },
                  React.createElement('div', { style: { textAlign: 'center', marginBottom: '10px' } },
                    React.createElement('h3', { style: { margin: 0, color: '#0f172a', fontSize: '18px', fontWeight: 'bold' } }, title),
                    React.createElement('p', { style: { margin: '4px 0 0 0', fontSize: '12px', color: '#475569' } }, subtitle)
                  ),
                  items.length === 0 
                    ? React.createElement('div', { style: { padding: '30px', color: '#64748b', fontSize: '14px', border: '1px dashed #cbd5e1', width: '100%', textAlign: 'center', borderRadius: '8px' } }, 'Bấm nút "Add" ở mục Danh sách các Ban để thêm dữ liệu')
                    : React.createElement('div', { style: { display: 'grid', gridTemplateColumns: 'repeat(auto-fit, minmax(200px, 1fr))', gap: '20px', width: '100%', justifyContent: 'center' } },
                        items.map((ban, index) => {
                          const isUrlIcon = ban.icon && (ban.icon.startsWith('http') || ban.icon.startsWith('/'));
                          return React.createElement('div', { key: index, style: { background: ban.custom_button_color || '#3b82f6', borderRadius: `${ban.custom_button_radius || 8}px`, padding: '25px 20px', textAlign: 'center', display: 'flex', flexDirection: 'column', alignItems: 'center', justifyContent: 'center' } },
                            isUrlIcon ? React.createElement('img', { src: ban.icon, style: { width: '40px', height: '40px', marginBottom: '10px', objectFit: 'contain' } }) : React.createElement('span', { style: { fontSize: '28px', marginBottom: '10px' } }, ban.icon || '💼'),
                            React.createElement('span', { style: { color: ban.custom_text_color || '#ffffff', fontSize: `${ban.custom_text_size || 14}px`, fontWeight: '600', display: 'block', marginBottom: '15px' } }, ban.name || 'Ban chưa đặt tên'),
                            React.createElement('button', { style: { background: 'rgba(255,255,255,0.2)', border: '1px solid rgba(255,255,255,0.4)', color: '#fff', padding: '4px 12px', borderRadius: '12px', fontSize: '11px' } }, ban.button_text || 'Xem thêm')
                          );
                        })
                      )
                )
              );
            }
          },

          // --- COMPONENT VỀ CLB & CƠ CẤU TỔ CHỨC ---
          VềCâuLạcBộVàCơCấu: {
            label: 'Về CLB & Cơ cấu ',
            fields: {
              background: { type: 'object', label: 'Cấu hình Nền & Padding', objectFields: backgroundFields },
              columns: {
                type: 'array',
                label: 'Cấu hình các Cột',
                getItemSummary: (col) => col.title || 'Cột chưa đặt tên',
                arrayFields: {
                  title: { type: 'text', label: 'Tiêu đề cột' },
                  type: {
                    type: 'select', label: 'Loại hiển thị của cột',
                    options: [{ label: 'Đoạn chữ + Ảnh phía dưới', value: 'text_with_image' }, { label: 'Danh sách nhân sự (Cơ cấu)', value: 'members_list' }]
                  },
                  content_text: { type: 'textarea', label: 'Đoạn văn giới thiệu' },
                  image_url: { type: 'text', label: 'URL hình ảnh dưới chân cột' },
                  members: {
                    type: 'array',
                    label: 'Danh sách nhân sự (Người)',
                    getItemSummary: (m) => m.name || 'Nhân sự chưa đặt tên',
                    arrayFields: {
                      avatar: { type: 'text', label: 'URL ảnh đại diện' },
                      name: { type: 'text', label: 'Họ và tên nhân sự' },
                      role: { type: 'text', label: 'Chức danh / Vị trí' },
                      company: { type: 'text', label: 'Tên Doanh nghiệp / Đơn vị' }
                    }
                  }
                }
              }
            },
            defaultProps: { background: defaultBackgroundProps, columns: [] },
            render: ({ background, columns = [] }) => {
              const bgStyle = getBackgroundStyle(background);
              return React.createElement('div', { style: { ...bgStyle, width: '100%', boxSizing: 'border-box', display: 'flex', justifyContent: 'center' } },
                columns.length === 0
                  ? React.createElement('div', { style: { padding: '40px', color: '#64748b', fontSize: '14px', border: '1px dashed #cbd5e1', maxWidth: '800px', width: '100%', textAlign: 'center', borderRadius: '8px', background: '#fff' } }, 'Bấm nút "Add" ở mục Cấu hình các Cột để tạo nội dung')
                  : React.createElement('div', { style: { display: 'flex', gap: '30px', maxWidth: '1200px', width: '100%', flexWrap: 'wrap', justifyContent: 'center' } },
                      columns.map((col, idx) => {
                        const isMembersList = col.type === 'members_list';
                        return React.createElement('div', { key: idx, style: { flex: '1', minWidth: '300px', maxWidth: '560px', background: '#ffffff', borderRadius: '12px', padding: '30px', boxShadow: '0 4px 20px rgba(0,0,0,0.03)', display: 'flex', flexDirection: 'column', justifyContent: 'space-between', border: '1px solid #e2e8f0' } },
                          React.createElement('div', null,
                            React.createElement('h3', { style: { fontSize: '18px', color: '#1e293b', fontWeight: 'bold', marginBottom: '20px', borderBottom: '2px solid #3b82f6', paddingBottom: '6px', display: 'inline-block' } }, col.title || 'TIÊU ĐỀ CỘT'),
                            !isMembersList && React.createElement('p', { style: { fontSize: '14px', color: '#334155', lineHeight: '1.6', marginBottom: '20px' } }, col.content_text || 'Chưa nhập nội dung chữ...'),
                            isMembersList && React.createElement('div', { style: { display: 'flex', flexDirection: 'column', gap: '15px' } },
                              (!col.members || col.members.length === 0)
                                ? React.createElement('p', { style: { fontSize: '13px', color: '#94a3b8' } }, 'Chưa có nhân sự.')
                                : col.members.map((m, mIdx) =>
                                    React.createElement('div', { key: mIdx, style: { display: 'flex', alignItems: 'center', gap: '15px', paddingBottom: '12px', borderBottom: '1px solid #f1f5f9' } },
                                      React.createElement('img', { src: m.avatar || 'https://via.placeholder.com/150', alt: m.name, style: { width: '48px', height: '48px', borderRadius: '50%', objectFit: 'cover', background: '#e2e8f0' } }),
                                      React.createElement('div', null,
                                        React.createElement('h4', { style: { margin: 0, fontSize: '14px', fontWeight: 'bold', color: '#0f172a' } }, m.name || 'Tên nhân sự'),
                                        React.createElement('p', { style: { margin: '2px 0 0 0', fontSize: '12px', color: '#475569' } }, m.role || 'Chức vụ'),
                                        React.createElement('p', { style: { margin: '2px 0 0 0', fontSize: '11px', color: '#64748b' } }, m.company || 'Công ty')
                                      )
                                    )
                                  )
                            )
                          ),
                          !isMembersList && col.image_url && React.createElement('div', { style: { width: '100%', height: '170px', overflow: 'hidden', borderRadius: '6px', marginTop: '15px' } },
                            React.createElement('img', { src: col.image_url, style: { width: '100%', height: '100%', objectFit: 'cover' } })
                          ),
                          isMembersList && React.createElement('div', { style: { display: 'flex', alignItems: 'center', gap: '10px', marginTop: '20px', fontSize: '12px', color: '#94a3b8', justifyContent: 'center' } },
                            React.createElement('span', null, '◀'), React.createElement('span', null, '• 1 — 2 •'), React.createElement('span', null, '▶')
                          )
                        );
                      })
                    )
              );
            }
          }
        }
      };

      const container = document.getElementById('puck-root');
      if (container) {
        const root = createRoot(container);
        root.render(
          React.createElement(Puck, {
            config: puckConfigLocal,
            data: { content: [], root: {} },
            onChange: (data) => console.log("Data thay đổi:", data)
          })
        );
      }
    </script>

    <style is:global>
      html, body {
        margin: 0;
        padding: 0;
        height: auto !important;
        width: 100vw;
        overflow-y: auto !important;
        overflow-x: hidden;
        font-family: system-ui, -apple-system, sans-serif;
      }
    </style>
  </body>
</html>